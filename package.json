{
  "name": "luna",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "start:server": "tsx apps/server/src/main.ts",
    "start:agent": "tsx apps/agent/src/main.ts",
    "start:web": "npm --workspace apps/web run dev"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "ws": "^8.20.0"
  }
}
